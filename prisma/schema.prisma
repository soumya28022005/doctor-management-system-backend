generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CLINIC
  RECEPTIONIST
  DOCTOR
  PATIENT
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum QueueMode {
  LIVE
  PRIVATE
  TIME_SLOT
}

enum QueueStatus {
  OPEN
  PAUSED
  CLOSED
}

enum AppointmentStatus {
  WAITING
  CHECKED_IN
  ABSENT
  COMPLETED
  CANCELLED
}

enum BookingSource {
  ONLINE
  RECEPTION
  WALK_IN
  PHONE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum RequestedBy {
  DOCTOR
  CLINIC
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}


model User {
  id             String       @id @default(uuid())
  name           String
  email          String?      @unique
  password       String?
  phone          String?      @unique
  role           Role
  provider       AuthProvider @default(LOCAL)
  googleId       String?      @unique
  avatar         String?
  isVerified     Boolean      @default(false)
  isActive       Boolean      @default(true)
  refreshToken   String?
  selfRegistered Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic       Clinic?
  doctor       Doctor?
  receptionist Receptionist?
  patient      Patient?

  @@map("users")
}

model Clinic {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String   @unique
  clinicName String
  address    String?
  city       String?
  state      String?
  pincode    String?
  latitude   Float?
  longitude  Float?
  logo       String?
  isApproved Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors             Doctor[]
  receptionists       Receptionist[]
  announcements       Announcement[]
  doctorAssociations  DoctorClinicAssociation[]

  @@map("clinics")
}

model Doctor {
  id             String    @id @default(uuid())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String    @unique
  clinic         Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  clinicId       String
  specialization String?
  qualification  String?
  experience     Int?
  fee            Float?
  isVerified     Boolean   @default(false)
  queueMode      QueueMode @default(LIVE)
  startTime      String?
  profilePhoto   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedReceptionists ReceptionistDoctor[]
  queues                Queue[]
  appointments          Appointment[]
  announcements         Announcement[]
  clinicAssociations    DoctorClinicAssociation[]

  @@map("doctors")
}

model Receptionist {
  id       String @id @default(uuid())
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String @unique
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  clinicId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedDoctors ReceptionistDoctor[]

  @@map("receptionists")
}

model ReceptionistDoctor {
  id             String       @id @default(uuid())
  receptionist   Receptionist @relation(fields: [receptionistId], references: [id], onDelete: Cascade)
  receptionistId String
  doctor         Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId       String

  createdAt DateTime @default(now())

  @@unique([receptionistId, doctorId])
  @@map("receptionist_doctors")
}

model Patient {
  id     String  @id @default(uuid())
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @unique

  // For guest/walk-in patients who have no login account —
  // these hold the identity directly on the Patient record.
  // For self-registered patients, name/phone live on the linked User instead.
  name  String?
  phone String?

  dob        DateTime?
  age        Int?
  gender     String?
  bloodGroup String?
  address    String?
  latitude   Float?
  longitude  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@map("patients")
}

model Queue {
  id              String      @id @default(uuid())
  doctor          Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId        String
  date            DateTime    @db.Date
  currentToken    Int         @default(0)
  lastTokenIssued Int         @default(0)
  status          QueueStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  logs         QueueLog[]

  @@unique([doctorId, date])
  @@map("queues")
}

model QueueLog {
  id          String   @id @default(uuid())
  queue       Queue    @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId     String
  action      String
  performedBy String
  meta        Json?

  createdAt DateTime @default(now())

  @@map("queue_logs")
}

model Appointment {
  id            String            @id @default(uuid())
  doctor        Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId      String
  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId     String
  queue         Queue             @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId       String
  token         Int
  date          DateTime          @db.Date
  status        AppointmentStatus @default(WAITING)
  bookingSource BookingSource
  isEmergency   Boolean           @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, date, token])
  @@map("appointments")
}

// Singleton table — always exactly one row — holds platform-wide configurable settings
model PlatformSetting {
  id                   String @id @default(uuid())
  bookingWindowMinutes Int    @default(180)

  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

enum AnnouncementType {
  DOCTOR_ABSENT
  CLINIC_CLOSED
  HOLIDAY
  EMERGENCY
  MAINTENANCE
  GENERAL
}

model Announcement {
  id        String           @id @default(uuid())
  type      AnnouncementType
  title     String
  message   String

  // null clinicId = platform-wide (posted by Admin/Super Admin)
  clinic   Clinic? @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  clinicId String?

  // optional — ties the notice to one specific doctor (e.g. "Dr. X absent today")
  doctor   Doctor? @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId String?

  createdByUserId String
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model DoctorClinicAssociation {
  id       String @id @default(uuid())
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  clinicId String

  fee       Float?
  queueMode QueueMode @default(LIVE)

  dayOfWeek DayOfWeek
  startTime String // "HH:mm"
  endTime   String // "HH:mm"

  status      RequestStatus @default(PENDING)
  requestedBy RequestedBy

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("doctor_clinic_associations")
}


