generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CLINIC
  RECEPTIONIST
  DOCTOR
  PATIENT
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum QueueMode {
  LIVE
  PRIVATE
  TIME_SLOT
}

enum QueueStatus {
  OPEN
  PAUSED
  CLOSED
}

enum AppointmentStatus {
  WAITING
  CHECKED_IN
  ABSENT
  COMPLETED
  CANCELLED
}

enum BookingSource {
  ONLINE
  RECEPTION
  WALK_IN
  PHONE
}

model User {
  id             String       @id @default(uuid())
  name           String
  email          String?      @unique
  password       String?
  phone          String?      @unique
  role           Role
  provider       AuthProvider @default(LOCAL)
  googleId       String?      @unique
  avatar         String?
  isVerified     Boolean      @default(false)
  isActive       Boolean      @default(true)
  refreshToken   String?
  selfRegistered Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic       Clinic?
  doctor       Doctor?
  receptionist Receptionist?
  patient      Patient?

  @@map("users")
}

model Clinic {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String   @unique
  clinicName String
  address    String?
  city       String?
  state      String?
  pincode    String?
  latitude   Float?
  longitude  Float?
  isApproved Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors       Doctor[]
  receptionists Receptionist[]

  @@map("clinics")
}

model Doctor {
  id             String    @id @default(uuid())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String    @unique
  clinic         Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  clinicId       String
  specialization String?
  qualification  String?
  experience     Int?
  fee            Float?
  isVerified     Boolean   @default(false)
  queueMode      QueueMode @default(LIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedReceptionists ReceptionistDoctor[]
  queues                Queue[]
  appointments          Appointment[]

  @@map("doctors")
}

model Receptionist {
  id       String @id @default(uuid())
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String @unique
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  clinicId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedDoctors ReceptionistDoctor[]

  @@map("receptionists")
}

model ReceptionistDoctor {
  id             String       @id @default(uuid())
  receptionist   Receptionist @relation(fields: [receptionistId], references: [id], onDelete: Cascade)
  receptionistId String
  doctor         Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId       String

  createdAt DateTime @default(now())

  @@unique([receptionistId, doctorId])
  @@map("receptionist_doctors")
}

model Patient {
  id     String  @id @default(uuid())
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @unique

  // For guest/walk-in patients who have no login account —
  // these hold the identity directly on the Patient record.
  // For self-registered patients, name/phone live on the linked User instead.
  name  String?
  phone String?

  dob        DateTime?
  age        Int?
  gender     String?
  bloodGroup String?
  address    String?
  latitude   Float?
  longitude  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@map("patients")
}

model Queue {
  id              String      @id @default(uuid())
  doctor          Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId        String
  date            DateTime    @db.Date
  currentToken    Int         @default(0)
  lastTokenIssued Int         @default(0)
  status          QueueStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@unique([doctorId, date])
  @@map("queues")
}

model Appointment {
  id            String            @id @default(uuid())
  doctor        Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId      String
  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId     String
  queue         Queue             @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId       String
  token         Int
  date          DateTime          @db.Date
  status        AppointmentStatus @default(WAITING)
  bookingSource BookingSource

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, date, token])
  @@map("appointments")
}